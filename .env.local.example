NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Meta for Developers App ID, used only to open Instagram's Story camera
# directly on iPhone (skipping the share sheet) from the "Share to Story"
# button. Optional — if unset, that button falls back to the standard Web
# Share API share sheet on every device.
NEXT_PUBLIC_META_APP_ID=
